# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database Configuration
DATABASE_URL=your_database_connection_string

# Authentication Configuration
NEXTAUTH_SECRET=your_nextauth_secret_key
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Video Streaming Configuration
CDN_BASE_URL=your_cdn_base_url
VIDEO_STORAGE_BUCKET=your_video_storage_bucket

# External APIs
ANILIST_API_URL=https://graphql.anilist.co
JIKAN_API_URL=https://api.jikan.moe/v4
YOUTUBE_API_KEY=your_youtube_api_key

# ⚡ REAL CRUNCHYROLL INTEGRATION - CRITICAL FOR AUTHENTIC CONTENT
# WeAnime ONLY displays real Crunchyroll content - NO MOCK DATA
# SECURITY: These are server-side only variables (not NEXT_PUBLIC_)
CRUNCHYROLL_EMAIL=your_crunchyroll_email
CRUNCHYROLL_PASSWORD=your_crunchyroll_password
CRUNCHYROLL_LOCALE=en-US
CRUNCHYROLL_BRIDGE_URL=http://localhost:8081

# Real Crunchyroll Backend
REAL_CRUNCHYROLL_BACKEND_URL=http://localhost:8003

# Legacy API Configuration (Optional)
CRUNCHYROLL_API_URL=https://api.crunchyroll.com/v1
CRUNCHYROLL_API_KEY=your_crunchyroll_api_key

# Funimation API
FUNIMATION_API_URL=https://api.funimation.com/v1
FUNIMATION_API_KEY=your_funimation_api_key

# Backend Configuration - REAL CONTENT ONLY
NEXT_PUBLIC_BACKEND_URL=http://localhost:8003
WEANIME_BACKEND_URL=http://localhost:8003
# NO FALLBACK URLs - WeAnime only uses real Crunchyroll backend
BACKEND_API_KEY=your_backend_api_key

# Security Configuration
JWT_SECRET=your_jwt_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here

# Email Configuration (Optional)
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password

# Analytics and Monitoring (Optional)
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id
SENTRY_DSN=your_sentry_dsn

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Kōkai Anime
NEXT_PUBLIC_APP_DESCRIPTION=Stream, track, and discover anime

# Feature Flags
NEXT_PUBLIC_ENABLE_COMMENTS=true
NEXT_PUBLIC_ENABLE_RATINGS=true
NEXT_PUBLIC_ENABLE_SOCIAL_FEATURES=true

# 🚫 MOCK DATA POLICY - ZERO TOLERANCE
NEXT_PUBLIC_MOCK_DATA_ENABLED=false
NEXT_PUBLIC_REAL_STREAMING_ONLY=true
NEXT_PUBLIC_DEMO_MODE=false

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Cache Configuration
REDIS_URL=your_redis_url
CACHE_TTL=3600
