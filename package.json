{
  "name": "weanime",
  "version": "1.0.0",
  "description": "Modern anime streaming platform with glassmorphism design built with Next.js 15 and Supabase",
  "private": true,
  "keywords": [
    "anime",
    "streaming",
    "nextjs",
    "supabase",
    "glassmorphism",
    "react",
    "typescript"
  ],
  "author": "WeAnime Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Heather8769/weanime.git"
  },
  "bugs": {
    "url": "https://github.com/Heather8769/weanime/issues"
  },
  "homepage": "https://weanime.app",
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "dev:3000": "next dev --turbopack --port 3000",
    "dev:8000": "next dev --turbopack --port 8000",
    "build": "next build",
    "start": "next start",
    "start:3000": "PORT=3000 next start",
    "start:8000": "PORT=8000 next start",
    "start:multiport": "bash scripts/start-multiport.sh",
    "start:bridge": "bash scripts/start-crunchyroll-bridge.sh",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "db:generate": "mkdir -p src/types && supabase gen types typescript --project-id zwvilprhyvzwcrhkyhjy > src/types/database.types.ts",
    "docker:build": "docker build -t weanime .",
    "docker:run": "docker run -p 3000:3000 weanime",
    "analyze": "cross-env ANALYZE=true next build",
    "clean": "rm -rf .next out dist build",
    "validate-imports": "node scripts/import-validator.js",
    "recover-missing": "node scripts/recovery-assistant.js",
    "deploy-safe": "node scripts/deploy-with-recovery.js",
    "prebuild": "node scripts/deployment-recovery.js && node scripts/import-validator.js || true",
    "postinstall": "echo 'Skipping db:generate in production deployment'",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "deploy:production": "bash scripts/deploy-production.sh"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@supabase/supabase-js": "^2.39.0",
    "@tanstack/react-query": "^5.17.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "framer-motion": "^10.16.16",
    "jose": "^6.0.11",
    "lucide-react": "^0.513.0",
    "next": "^15.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-player": "^2.13.0",
    "tailwind-merge": "^2.2.0",
    "zod": "^3.25.63",
    "zustand": "^4.4.7",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "@tailwindcss/typography": "^0.5.10",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.3.3"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.11.3",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "cross-env": "^7.0.3",
    "dotenv": "^16.5.0",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "engines": {
    "node": ">=20.19.2",
    "npm": ">=10.0.0"
  }
}
