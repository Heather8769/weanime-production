{
  "name": "weanime",
  "version": "1.0.0",
  "description": "Modern anime streaming platform with glassmorphism design built with Next.js 15 and Supabase",
  "private": true,
  "keywords": [
    "anime",
    "streaming",
    "nextjs",
    "supabase",
    "glassmorphism",
    "react",
    "typescript"
  ],
  "author": "WeAnime Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/weanime.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/weanime/issues"
  },
  "homepage": "https://weanime.app",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:unit": "jest --testPathPattern=__tests__",
    "test:integration": "jest --testPathPattern=integration",
    "db:generate": "supabase gen types typescript --project-id zwvilprhyvzwcrhkyhjy > src/types/database.types.ts",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase migration up",
    "db:seed": "supabase db seed",
    "docker:build": "docker build -t weanime .",
    "docker:run": "docker run -p 3000:3000 weanime",
    "analyze": "cross-env ANALYZE=true next build",
    "clean": "rm -rf .next out dist build",
    "prepare": "husky install",
    "prebuild": "npm run type-check && npm run lint",
    "postinstall": "npm run db:generate",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "deploy:production": "bash scripts/deploy-production.sh",
    "monitor:health": "node scripts/monitoring/dashboard-monitor.js health",
    "monitor:start": "node scripts/monitoring/dashboard-monitor.js start",
    "monitor:status": "node scripts/monitoring/dashboard-monitor.js status",
    "perf:test": "node scripts/performance-test.js",
    "perf:simple": "node scripts/simple-perf-test.js",
    "webhook:test": "node scripts/test-webhooks.js",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "update:deps": "npx npm-check-updates -u && npm install"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.0.2",
    "@supabase/supabase-js": "^2.39.0",
    "@tanstack/react-query": "^5.17.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "framer-motion": "^10.16.16",
    "lucide-react": "^0.513.0",
    "next": "^15.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-player": "^2.13.0",
    "tailwind-merge": "^2.2.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.16",
    "cross-env": "^7.0.3",
    "dotenv": "^16.5.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.3.3",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.0-beta.3",
    "lighthouse": "^12.6.1",
    "postcss": "^8.4.32",
    "puppeteer": "^24.10.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "engines": {
    "node": ">=20.19.2",
    "npm": ">=10.0.0"
  }
}
