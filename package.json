{
  "name": "weanime",
  "version": "1.0.0",
  "description": "Modern anime streaming platform with glassmorphism design built with Next.js 15 and Supabase",
  "private": true,
  "keywords": [
    "anime",
    "streaming",
    "nextjs",
    "supabase",
    "glassmorphism",
    "react",
    "typescript"
  ],
  "author": "WeAnime Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Heather8769/weanime.git"
  },
  "bugs": {
    "url": "https://github.com/Heather8769/weanime/issues"
  },
  "homepage": "https://weanime.app",
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "dev:3000": "next dev --turbopack --port 3000",
    "dev:8000": "next dev --turbopack --port 8000",
    "build": "next build",
    "start": "next start",
    "start:3000": "PORT=3000 next start",
    "start:8000": "PORT=8000 next start",
    "start:multiport": "bash scripts/start-multiport.sh",
    "start:bridge": "bash scripts/start-crunchyroll-bridge.sh",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:api": "jest --testPathPattern=api",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:performance": "jest --testPathPattern=performance",
    "test:security": "jest --testPathPattern=security",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:api && npm run test:e2e",
    "db:generate": "mkdir -p src/types && supabase gen types typescript --project-id zwvilprhyvzwcrhkyhjy > src/types/database.types.ts",
    "docker:build": "docker build -t weanime .",
    "docker:run": "docker run -p 3000:3000 weanime",
    "analyze": "cross-env ANALYZE=true next build",
    "clean": "rm -rf .next out dist build",
    "validate-imports": "node scripts/import-validator.js",
    "recover-missing": "node scripts/recovery-assistant.js",
    "deploy-safe": "node scripts/deploy-with-recovery.js",
    "prebuild": "node scripts/deployment-recovery.js && node scripts/import-validator.js || true",
    "postinstall": "echo 'Skipping db:generate in production deployment'",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "deploy:production": "bash scripts/deploy-production.sh",
    "build:optimized": "NODE_OPTIONS='--max-old-space-size=1024' next build",
    "deploy": "npm run build:optimized && netlify deploy --prod",
    "deploy:test": "npm run build:optimized && netlify deploy",
    "test:local": "npm run build && npm run start",
    "test:memory": "node --max-old-space-size=1024 node_modules/.bin/next build",
    "health": "curl -s http://localhost:3000/api/health | jq .",
    "optimize": "node scripts/production-optimize.js",
    "fix-logs": "node scripts/remove-production-logs.js"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@supabase/supabase-js": "^2.39.0",
    "@tailwindcss/typography": "^0.5.10",
    "@tanstack/react-query": "^5.17.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/bcryptjs": "^2.4.6",
    "autoprefixer": "^10.4.16",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.3.3",
    "framer-motion": "^10.16.16",
    "jose": "^6.0.11",
    "lucide-react": "^0.513.0",
    "next": "^15.3.3",
    "postcss": "^8.4.32",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-player": "^2.13.0",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "zod": "^3.25.63",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.3",
    "@jest/types": "^30.0.1",
    "@netlify/plugin-nextjs": "^5.11.3",
    "@playwright/test": "^1.40.1",
    "@testing-library/jest-dom": "^6.1.6",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/supertest": "^6.0.2",
    "cross-env": "^7.0.3",
    "dotenv": "^16.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "msw": "^2.0.11",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "engines": {
    "node": ">=20.19.2",
    "npm": ">=10.0.0"
  }
}
